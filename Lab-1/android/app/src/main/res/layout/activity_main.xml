<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.01" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitle"
            android:textSize="14sp"
            android:alpha="0.6" />

        <!-- Status card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22808080">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <FrameLayout
                    android:id="@+id/statusCircle"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:background="@drawable/status_circle"
                    android:backgroundTint="#9CA3AF">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_screencast"
                        android:contentDescription="@string/app_name" />
                </FrameLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/status_ready"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/statusHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="@string/status_ready_hint"
                    android:textSize="14sp"
                    android:alpha="0.6" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22808080">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout style="@style/InfoRow">
                    <TextView style="@style/InfoKey" android:text="@string/info_device" />
                    <TextView android:id="@+id/deviceValue" style="@style/InfoValue" />
                </LinearLayout>

                <View style="@style/InfoDivider" />

                <LinearLayout style="@style/InfoRow">
                    <TextView style="@style/InfoKey" android:text="@string/info_server" />
                    <TextView android:id="@+id/serverValue" style="@style/InfoValue" />
                </LinearLayout>

                <View style="@style/InfoDivider" />

                <LinearLayout style="@style/InfoRow">
                    <TextView style="@style/InfoKey" android:text="@string/info_mode" />
                    <TextView style="@style/InfoValue" android:text="@string/info_mode_value" />
                </LinearLayout>

                <View style="@style/InfoDivider" />

                <LinearLayout style="@style/InfoRow">
                    <TextView style="@style/InfoKey" android:text="@string/info_control" />
                    <TextView android:id="@+id/controlValue" style="@style/InfoValue" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/streamButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:text="@string/btn_enable_stream"
            android:textSize="16sp"
            app:icon="@drawable/ic_screencast"
            app:iconGravity="textStart"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/controlButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_enable_control"
            android:textSize="16sp"
            app:cornerRadius="16dp" />
    </LinearLayout>
</ScrollView>
